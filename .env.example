# Astra AI Content OS — Environment configuration template
# Copy to the repository root as .env. Never commit .env to version control.

# Application
APP_NAME=Astra AI Content OS
APP_VERSION=0.1.0
ENVIRONMENT=local
DEBUG=true
HOST=0.0.0.0
PORT=8000

# PostgreSQL
POSTGRES_USER=astra
POSTGRES_PASSWORD=change-me
POSTGRES_DB=astra
POSTGRES_PORT=5432
DATABASE_URL=postgresql://astra:change-me@localhost:5432/astra

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Research providers
TAVILY_API_KEY=

# AI providers
OPENAI_API_KEY=

# TTS providers
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
